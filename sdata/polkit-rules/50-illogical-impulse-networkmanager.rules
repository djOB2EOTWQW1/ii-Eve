// Allow users in the wheel group on an active local session to control
// NetworkManager without entering the root password. Without this the
// Wi-Fi toggle / connect / disconnect actions from Quickshell trigger a
// polkit dialog on every click.
polkit.addRule(function(action, subject) {
    if (action.id.indexOf("org.freedesktop.NetworkManager.") === 0 &&
        subject.local && subject.active && subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }
});
